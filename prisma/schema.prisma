// Skema Prisma ORM untuk Database PostgreSQL Hacienda Asset Management
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Password Hash (Bcrypt)
  role      String   @default("operator") // admin atau operator
  status    String   @default("Aktif")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  audits    Audit[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  assets      Asset[]
  createdAt   DateTime @default(now())
}

model Asset {
  id              String        @id // ID Kustom e.g., AST-001
  name            String
  categoryName    String
  category        Category      @relation(fields: [categoryName], references: [name])
  status          String        @default("Active") // Active atau Maintenance
  serial          String        @unique
  purchaseDate    DateTime?
  price           Decimal       @db.Decimal(12, 2)
  description     String?
  nextMaintenance DateTime?
  audits          Audit[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Audit {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  condition String   // Baik, Rusak Ringan, Rusak Berat
  pic       String
  photoUrl  String?  // Image url Cloudinary / S3
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}